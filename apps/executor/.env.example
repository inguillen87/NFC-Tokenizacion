# nexID tokenization executor
# Deploy this as a separate backend service when API should not hold the minter key.
PORT=3010
TOKENIZATION_EXECUTOR_SECRET=replace-with-long-random-secret

# Amoy pilot signer. Use only a dedicated testnet wallet.
EXECUTOR_SIGNER_MODE=private_key
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-key
POLYGON_MINTER_PRIVATE_KEY=0x...
POLYGON_CONTRACT_ADDRESS=0x...
POLYGON_DEFAULT_RECIPIENT=0x...

# Optional: set true only when you want /health to hit the chain.
EXECUTOR_HEALTH_LIVE=false
