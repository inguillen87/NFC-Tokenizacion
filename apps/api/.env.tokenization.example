# nexID Tokenization / Polygon Amoy
# simulated = demo/sandbox UX.
# polygon = real Amoy tx required; no simulated anchor fallback.
#
# Before enabling polygon, run:
# npm run tokenization:check
TOKENIZATION_MODE=simulated
SUN_AUTO_TOKENIZE_ON_VALID_TAP=false
TOKENIZATION_UID_SALT=replace-with-long-random-string
TOKENIZATION_METADATA_CID_PREFIX=nexid-metadata

# Option A: Polygon Amoy local minter runtime. Backend/API only. Never use NEXT_PUBLIC_*.
# TOKENIZATION_USE_LOCAL_MINTER=true
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-key
POLYGON_MINTER_PRIVATE_KEY=0x...
POLYGON_CONTRACT_ADDRESS=0x...
POLYGON_DEFAULT_RECIPIENT=0x...
POLYGON_DEPLOY_OWNER=0x...

# Option B: premium executor/KMS-style boundary. Use instead of POLYGON_MINTER_PRIVATE_KEY in API.
# The executor service keeps POLYGON_RPC_URL, POLYGON_MINTER_PRIVATE_KEY, CONTRACT and RECIPIENT.
# TOKENIZATION_USE_LOCAL_MINTER=false
# TOKENIZATION_EXECUTOR_URL=https://executor.nexid.lat/mint
# TOKENIZATION_EXECUTOR_SECRET=replace-with-long-random-secret
