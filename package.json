{
  "name": "product-identity-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:dashboard": "npm run dev --workspace=dashboard",
    "dev:api": "npm run dev --workspace=api",
    "build:web": "npm run build --workspace=web",
    "build:dashboard": "npm run build --workspace=dashboard",
    "build:api": "npm run build --workspace=api",
    "typecheck:dashboard": "npm run typecheck --workspace=dashboard",
    "build": "npm run build --workspaces --if-present",
    "db:new": "npm run db:new --workspace=api --",
    "db:migrate": "npm run db:migrate --workspace=api",
    "db:seed": "npm run db:seed --workspace=api",
    "db:reset:local": "npm run db:reset:local --workspace=api",
    "demo:demobodega": "npm run demo:demobodega --workspace=api",
    "demo:seed": "npm run demo:seed --workspace=api"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20.11.1"
  }
}
